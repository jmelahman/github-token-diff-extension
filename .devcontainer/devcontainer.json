{
  "name": "Personal Dev Sandbox",
  "image": "lahmanja/devcontainer@sha256:fb60d282922707ad96e6462bbddb824464ee8da6487619245655dde227b35b5a",
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--network=kanban-net"
  ],
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.claude.json,type=bind",
    "source=${localEnv:HOME}/.zshrc,target=${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.zshrc.host,type=bind,readonly",
    "source=${localEnv:HOME}/.config/nvim,target=${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.config/nvim,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.gitconfig,type=bind,readonly",
    "source=devcontainer-go-mod,target=/home/dev/go/pkg/mod,type=volume",
    "source=devcontainer-cache,target=${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.cache,type=volume",
    "source=devcontainer-local,target=${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.local,type=volume",
    "source=devcontainer-npm,target=${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.npm,type=volume"
  ],
  "containerEnv": {
    "COLORTERM": "truecolor",
    "DEVCONTAINER_FIREWALL": "${localEnv:DEVCONTAINER_FIREWALL}",
    "GH_TOKEN": "${localEnv:GH_TOKEN}",
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock",
    "XDG_RUNTIME_DIR": "${localEnv:XDG_RUNTIME_DIR}",
    "KANBAN_HOST_WORKSPACE": "${localWorkspaceFolder}",
    "KANBAN_HOST_HOME": "${localEnv:HOME}"
  },
  "remoteUser": "${localEnv:DEVCONTAINER_REMOTE_USER:dev}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "mkdir -p ${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.ssh && { ssh-add -L > ${localEnv:DEVCONTAINER_REMOTE_HOME:/home/dev}/.ssh/id_rsa.pub 2>/dev/null || true; } && sudo --preserve-env=DEVCONTAINER_FIREWALL bash -c 'if [ -f /workspace/.devcontainer/init-firewall.sh ]; then bash /workspace/.devcontainer/init-firewall.sh; else /usr/local/bin/init-firewall.sh; fi'",
  "waitFor": "postStartCommand"
}
